{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning",
      "Comprexy": "Information"
    }
  },
  "AllowedHosts": "*",
    "ConnectionStrings": {
      "Comprexy": "Data Source=comprexy.db;Cache=Shared"
    },
  "Provider": {
    "Type": "OpenAICompatible",
    "BaseUrl": "http://localhost:11434/v1",
    "ApiKey": null,
    "Model": "local-model",
    "TimeoutSeconds": 120
  },
  "Compression": {
    "BaseUrl": null,
    "ApiKey": null,
    "Model": null,
    "TimeoutSeconds": 600,
    "Temperature": 0.6,
    "EnableThinking": false,
    "InstructionFile": "Prompts/compression-fixed.md",
    "SmartInstructionFile": "Prompts/compression-smart.md"
  },
  "ContextPolicy": {
    "SoftLimitTokens": 60000,
    "HardLimitTokens": 64000,
    "CompressionMaxInputTokens": 65536,
    "EmergencyCompression": "Sync",
    "CancelBackgroundCompressionOnChat": false,
    "RetainSelection": "Smart",
    "CompressionRetainMessageCount": 1,
    "EmergencyRecentMessageCount": 1,
    "MaxRecentRawTokens": 24000,
    "SmartRetainMaxMessages": 8,
    "SmartRetainMaxTokens": 24000,
    "DedupeDuplicateFileReads": true,
    "TokenizerEncoding": "cl100k_base"
  },
  "Auth": {
    "RequiredApiKey": null
  },
  "Proxy": {
    "PassThrough": false,
    "StripReasoningContent": true
  },
  "Trace": {
    "ClientInput": false,
    "ClientOutput": false,
    "ModelInput": false,
    "ModelOutput": false,
    "CompressionModelInput": false,
    "CompressionModelOutput": false,
    "ContextBudget": false,
    "RequestFiles": false,
    "RequestLogDirectory": "logs/requests",
    "MaxPayloadChars": 32768
  },
  "Comprexy": {
    "TokenEstimateCache": {
      "AbsoluteExpiration": "00:15:00",
      "SizeLimit": 10000
    }
  }
}
