{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Comprexy": "Information"
    }
  },
  "ContextPolicy": {
    "RetainSelection": "Smart"
  },  
  "Trace": {
    "ClientInput": false,
    "ClientOutput": false,
    "ModelInput": false,
    "ModelOutput": false,
    "CompressionModelInput": false,
    "CompressionModelOutput": false,
    "ContextBudget": true,
    "RequestFiles": false,
    "RequestLogDirectory": "logs/requests"
  }
}
