{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning",
      "Comprexy": "Information"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Comprexy": "Data Source=comprexy.db;Cache=Shared"
  },
  "Auth": {
    "RequiredApiKey": null
  },
  "Metrics": {
    "Enabled": true
  }
}
